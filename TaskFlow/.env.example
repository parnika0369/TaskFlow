# PostgreSQL (DB_HOST overridden to 'postgres' by docker-compose for Docker)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=taskflow
DB_USER=taskflow
DB_PASSWORD=taskflow_secret

# JWT — must be at least 32 chars (UTF-8: 1 char = 1 byte = 8 bits, 32 × 8 = 256 bits for HS256)
JWT_SECRET=change-this-to-a-very-long-random-secret-key-at-least-32-chars

# Ports
SERVER_PORT=8080
FRONTEND_PORT=3000
POSTGRES_PORT=5432
